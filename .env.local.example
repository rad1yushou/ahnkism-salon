# Supabase
# Project URL: Supabase ダッシュボード > Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=

# anon public key: Supabase ダッシュボード > Settings > API > Project API keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role secret key: Supabase ダッシュボード > Settings > API > Project API keys > service_role
# ※ サーバーサイドのみ使用。ブラウザに露出させないこと。Vercel環境変数にも登録すること。
SUPABASE_SERVICE_ROLE_KEY=
